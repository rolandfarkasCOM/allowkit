{
  "name": "allowkit",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal, developer-first consent backend for GA4, Microsoft Clarity and Brevo. Cloudflare Worker + KV + D1.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply allowkit_audit --local",
    "db:migrate:remote": "wrangler d1 migrations apply allowkit_audit --remote",
    "db:reset:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/db-reset.ps1"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  }
}
